{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
  "moduleResolution": "Bundler",
  "target": "ES2022",
  "outDir": "../../dist/out-tsc",
    "declaration": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
